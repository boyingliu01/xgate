# Auto-detect text files and normalize line endings
* text=auto

# Shell scripts must always have LF line endings (#!/bin/bash requires it)
*.sh text eol=lf

# JS/TS source files
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# Config files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Markdown
*.md text eol=lf

# Binary files - never touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.eot binary
*.ttf binary

# Lock files
package-lock.json binary
